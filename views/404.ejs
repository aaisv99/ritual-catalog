<!DOCTYPE html>
<html lang="ru">
<head>
  <%- include('_head') %>
  <style>
    .error-page {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 60vh;
      text-align: center;
      padding: 48px 16px;
    }
    .error-page__code {
      font-size: 6rem;
      font-weight: 700;
      color: var(--color-border, #E2E6EA);
      line-height: 1;
      margin-bottom: 16px;
      font-family: var(--font-heading, 'Montserrat', sans-serif);
    }
    .error-page__title {
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--color-text, #2F343A);
      margin-bottom: 12px;
    }
    .error-page__desc {
      font-size: 1rem;
      color: var(--color-text-secondary, #6B7280);
      margin-bottom: 32px;
    }
  </style>
</head>
<body>

  <%- include('_header') %>

  <main>
    <div class="container">
      <div class="error-page">
        <div class="error-page__code">404</div>
        <h1 class="error-page__title">Страница не найдена</h1>
        <p class="error-page__desc">Запрошенная страница не существует или была удалена.</p>
        <a href="/" class="btn btn--primary">На главную</a>
      </div>
    </div>
  </main>

  <%- include('_footer') %>

  <script src="/js/site.js"></script>
</body>
</html>

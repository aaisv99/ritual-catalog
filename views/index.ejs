<!DOCTYPE html>
<html lang="ru">
<head>
  <%- include('_head') %>
</head>
<body>

  <%- include('_header') %>

  <main>

    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <p class="hero__eyebrow"><%= content['hero.eyebrow'] || 'Ритуальные товары' %></p>
        <h1 class="hero__title"><%= content['hero.title'] || 'Каталог ритуальных товаров' %></h1>
        <div class="hero__divider"></div>
        <p class="hero__subtitle"><%= content['hero.subtitle'] || 'Венки · Корзины · Полянки · Гробницы' %></p>
      </div>
    </section>

    <!-- Разделы каталога -->
    <section class="section" id="catalog">
      <div class="container">
        <div class="section__header">
          <h2 class="section__title">Разделы каталога</h2>
          <p class="section__subtitle">Выберите нужный раздел для просмотра товаров</p>
        </div>
        <div class="categories-grid">
          <% for (const cat of categories) { %>
          <a href="/catalog/<%= cat.slug %>" class="category-card">
            <div class="category-card__name"><%= cat.name %></div>
            <div class="category-card__desc"><%= cat.description %></div>
            <span class="category-card__arrow">→</span>
          </a>
          <% } %>
        </div>
      </div>
    </section>

    <!-- Информационный блок -->
    <section class="section section--gray">
      <div class="container">
        <div class="notice-block">
          <span class="notice-block__icon">ℹ</span>
          <p><%= content['site.notice'] || '' %></p>
        </div>
      </div>
    </section>

  </main>

  <%- include('_footer') %>

  <script src="/js/site.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="ru">
<head>
  <%- include('_head') %>
</head>
<body>

  <%- include('_header') %>

  <main class="catalog-page">
    <div class="container">

      <!-- Хлебные крошки -->
      <nav class="breadcrumbs" aria-label="Хлебные крошки">
        <a href="/" class="breadcrumbs__link">Главная</a>
        <span class="breadcrumbs__sep">→</span>
        <span class="breadcrumbs__current"><%= category.name %></span>
      </nav>

      <!-- Заголовок + оптовый badge -->
      <div class="catalog-topbar">
        <h1 class="catalog-topbar__title"><%= category.name %></h1>
        <span class="wholesale-badge">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="10" cy="10" r="8"/><path d="M10 6v4l2.5 2.5" stroke-linecap="round"/></svg>
          Цены оптовые — розничные уточняйте отдельно
        </span>
      </div>

      <!-- Кнопка Фильтры (мобилка) -->
      <%
        const activeFiltersCount = (shapeFilter ? 1 : 0) + (colorFilter ? 1 : 0) + (heightFilter ? 1 : 0);
      %>
      <button class="mob-filter-btn" id="mob-filter-btn" aria-expanded="false">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M3 5h14M6 10h8M9 15h2" stroke-linecap="round"/>
        </svg>
        Фильтры
        <% if (activeFiltersCount > 0) { %><span class="mob-filter-btn__badge"><%= activeFiltersCount %></span><% } %>
      </button>

      <!-- Оверлей -->
      <div class="filters-backdrop" id="filters-backdrop"></div>

      <%
        const baseUrl = '/catalog/' + category.slug;
        function buildUrl(overrides) {
          const p = {};
          if (shapeFilter) p.shape = shapeFilter;
          if (colorFilter) p.color = colorFilter;
          if (heightFilter) p.height = heightFilter;
          Object.assign(p, overrides);
          // remove nulls/zeros
          const qs = Object.entries(p).filter(([,v]) => v).map(([k,v]) => k+'='+v).join('&');
          return baseUrl + (qs ? '?'+qs : '');
        }
      %>

      <div class="catalog-layout">

        <!-- ── Сайдбар фильтров ── -->
        <aside class="filters-sidebar" id="filters-sidebar" aria-label="Фильтры">

          <div class="filters-sidebar__head">
            <span class="filters-sidebar__title">Фильтры</span>
            <button class="filters-sidebar__close" id="filters-close" aria-label="Закрыть">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M4 4l12 12M16 4L4 16" stroke-linecap="round"/>
              </svg>
            </button>
          </div>

          <!-- Аккордеон: Форма -->
          <% if (shapes.length > 0) { %>
          <div class="f-accordion is-open" data-group="shape">
            <button class="f-accordion__header" aria-expanded="true">
              <span class="f-accordion__label">Форма</span>
              <svg class="f-accordion__arrow" width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 8l5 5 5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="f-accordion__body">
              <% for (const shape of shapes) { %>
              <%
                const isChecked = shapeFilter === shape.id;
                const cnt = shapeCounts[shape.id] || 0;
                const href = isChecked ? buildUrl({shape: null}) : buildUrl({shape: shape.id});
              %>
              <a href="<%= href %>" class="f-check-row<%= isChecked ? ' is-checked' : '' %><%= cnt === 0 && !isChecked ? ' is-disabled' : '' %>">
                <span class="f-check-box" aria-hidden="true">
                  <% if (isChecked) { %>
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M2 6l3 3 5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <% } %>
                </span>
                <span class="f-check-label"><%= shape.name %></span>
                <% if (cnt > 0) { %><span class="f-check-count"><%= cnt %></span><% } %>
              </a>
              <% } %>
            </div>
          </div>
          <% } %>

          <!-- Аккордеон: Цвет -->
          <% if (colors.length > 0) { %>
          <div class="f-accordion is-open" data-group="color">
            <button class="f-accordion__header" aria-expanded="true">
              <span class="f-accordion__label">Цвет</span>
              <svg class="f-accordion__arrow" width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 8l5 5 5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="f-accordion__body">
              <div class="f-swatch-grid">
                <% for (const color of colors) { %>
                <%
                  const isActive = colorFilter === color.id;
                  const cnt = colorCounts[color.id] || 0;
                  let dotStyle = '';
                  if (color.hex === 'tricolor') {
                    dotStyle = 'background: linear-gradient(to right, #cc0000 33%, #003478 33%, #003478 66%, #ffffff 66%);';
                  } else if (color.hex === 'mixed') {
                    dotStyle = 'background: conic-gradient(#e74c3c,#9b59b6,#3498db,#2ecc71,#f1c40f,#e74c3c);';
                  } else {
                    dotStyle = 'background:' + color.hex + ';';
                  }
                  const href2 = isActive ? buildUrl({color: null}) : buildUrl({color: color.id});
                %>
                <a href="<%= href2 %>"
                   class="f-swatch<%= isActive ? ' is-active' : '' %><%= cnt === 0 && !isActive ? ' is-empty' : '' %>"
                   title="<%= color.name %><%= cnt > 0 ? ' · ' + cnt : '' %>"
                   style="<%= dotStyle %>">
                  <% if (isActive) { %>
                  <svg class="f-swatch__check" width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="2.2" filter="url(#shadow)"><path d="M2 6l3 3 5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <% } %>
                </a>
                <% } %>
              </div>
              <% if (colorFilter && activeColor) { %>
              <div class="f-swatch-active-name"><%= activeColor.name %></div>
              <% } %>
            </div>
          </div>
          <% } %>

          <!-- Аккордеон: Высота -->
          <% if (heights.length > 0) { %>
          <div class="f-accordion is-open" data-group="height">
            <button class="f-accordion__header" aria-expanded="true">
              <span class="f-accordion__label">Высота</span>
              <svg class="f-accordion__arrow" width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 8l5 5 5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="f-accordion__body">
              <% for (const h of heights) { %>
              <%
                const isChecked2 = heightFilter === h.id;
                const cnt2 = heightCounts[h.id] || 0;
                const href3 = isChecked2 ? buildUrl({height: null}) : buildUrl({height: h.id});
              %>
              <a href="<%= href3 %>" class="f-check-row<%= isChecked2 ? ' is-checked' : '' %><%= cnt2 === 0 && !isChecked2 ? ' is-disabled' : '' %>">
                <span class="f-check-box" aria-hidden="true">
                  <% if (isChecked2) { %>
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M2 6l3 3 5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <% } %>
                </span>
                <span class="f-check-label"><%= h.label %></span>
                <% if (cnt2 > 0) { %><span class="f-check-count"><%= cnt2 %></span><% } %>
              </a>
              <% } %>
            </div>
          </div>
          <% } %>

          <!-- Мобильный нижний бар -->
          <div class="filters-mob-footer">
            <% if (activeFiltersCount > 0) { %>
            <a href="<%= baseUrl %>" class="btn btn--outline btn--sm">Сбросить</a>
            <% } else { %>
            <span></span>
            <% } %>
            <button class="btn btn--primary btn--sm" id="filters-apply-btn">
              Показать <%= total %> товаров
            </button>
          </div>

        </aside>

        <!-- ── Основной контент ── -->
        <div class="catalog-main">

          <!-- Чипы выбранных фильтров -->
          <% if (activeFiltersCount > 0) { %>
          <div class="active-filters">
            <% if (activeShape) { %>
            <a href="<%= buildUrl({shape: null}) %>" class="active-chip">
              <%= activeShape.name %>
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 2l10 10M12 2L2 12" stroke-linecap="round"/></svg>
            </a>
            <% } %>
            <% if (activeColor) { %>
            <%
              let chipDotStyle = '';
              if (activeColor.hex === 'tricolor') chipDotStyle = 'background: linear-gradient(to right, #cc0000 33%, #003478 33%, #003478 66%, #ffffff 66%);';
              else if (activeColor.hex === 'mixed') chipDotStyle = 'background: conic-gradient(#e74c3c,#9b59b6,#3498db,#2ecc71,#f1c40f,#e74c3c);';
              else chipDotStyle = 'background:' + activeColor.hex + ';';
            %>
            <a href="<%= buildUrl({color: null}) %>" class="active-chip">
              <span class="active-chip__dot" style="<%= chipDotStyle %>"></span>
              <%= activeColor.name %>
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 2l10 10M12 2L2 12" stroke-linecap="round"/></svg>
            </a>
            <% } %>
            <% if (activeHeight) { %>
            <a href="<%= buildUrl({height: null}) %>" class="active-chip">
              <%= activeHeight.label %>
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 2l10 10M12 2L2 12" stroke-linecap="round"/></svg>
            </a>
            <% } %>
            <a href="<%= baseUrl %>" class="active-filters__clear">Очистить всё</a>
          </div>
          <% } %>

          <!-- Счётчик -->
          <div class="catalog__count">
            <strong><%= total %></strong> товаров
            <% if (pages > 1) { %>&nbsp;· стр. <%= page %> из <%= pages %><% } %>
          </div>

          <!-- Сетка товаров -->
          <% if (products.length > 0) { %>
          <div class="products-grid">
            <% const PH = "data:image/svg+xml,%3Csvg width='56' height='56' viewBox='0 0 56 56' fill='none'%3E%3Crect x='3' y='3' width='50' height='50' rx='8' stroke='%23C8CDD4' stroke-width='1.5' fill='none'/%3E%3Cpath d='M14 42 L22 28 L29 36 L35 24 L44 42 H14Z' fill='%23C8CDD4' opacity='0.55'/%3E%3Ccircle cx='36' cy='19' r='5' fill='%23C8CDD4' opacity='0.55'/%3E%3C/svg%3E"; %>
            <% for (const product of products) { %>
            <a href="/catalog/<%= category.slug %>/<%= product.subcategory_slug %>/<%= product.slug %>" class="product-card">
              <div class="product-card__image">
                <% if (product.images && product.images.length > 0) { %>
                <img src="<%= product.images[0] %>" alt="<%= product.name %>" loading="lazy" onerror="this.src='<%= PH %>'">
                <% } else { %>
                <div class="product-card__placeholder"><img src="<%= PH %>" alt=""></div>
                <% } %>
              </div>
              <div class="product-card__body">
                <div class="product-card__name"><%= product.name %></div>
                <% if (product.colorObjects && product.colorObjects.length > 0) { %>
                <div class="product-card__colors">
                  <% for (const c of product.colorObjects) { %>
                  <%
                    let ds = '';
                    if (c.hex === 'tricolor') ds = 'background: linear-gradient(to right, #cc0000 33%, #003478 33%, #003478 66%, #ffffff 66%); border:1px solid #ccc;';
                    else if (c.hex === 'mixed') ds = 'background: conic-gradient(#e74c3c,#9b59b6,#3498db,#2ecc71,#f1c40f,#e74c3c);';
                    else ds = 'background:' + c.hex + '; border:1px solid rgba(0,0,0,.1);';
                  %>
                  <span class="color-dot" style="<%= ds %>" title="<%= c.name %>"></span>
                  <% } %>
                </div>
                <% } %>
                <div class="product-card__footer">
                  <span class="product-card__price"><%= product.price.toLocaleString('ru-RU') %>&nbsp;₽</span>
                  <span class="product-card__cta">Подробнее →</span>
                </div>
              </div>
            </a>
            <% } %>
          </div>

          <!-- Пагинация -->
          <% if (pages > 1) { %>
          <nav class="catalog-pagination" aria-label="Страницы">
            <% for (let i = 1; i <= pages; i++) { %>
            <%
              const pObj = {};
              if (shapeFilter) pObj.shape = shapeFilter;
              if (colorFilter) pObj.color = colorFilter;
              if (heightFilter) pObj.height = heightFilter;
              if (i > 1) pObj.page = i;
              const pQs = Object.entries(pObj).map(([k,v]) => k+'='+v).join('&');
              const pUrl = baseUrl + (pQs ? '?' + pQs : '');
            %>
            <a href="<%= pUrl %>" class="catalog-pagination__btn<%= i === page ? ' is-active' : '' %>"><%= i %></a>
            <% } %>
          </nav>
          <% } %>

          <% } else { %>
          <div class="products-empty">
            <div class="products-empty__icon">🔍</div>
            <p class="products-empty__title">Товары не найдены</p>
            <p class="products-empty__text">Попробуйте изменить или сбросить фильтры</p>
            <a href="<%= baseUrl %>" class="btn btn--outline" style="margin-top:16px">Сбросить фильтры</a>
          </div>
          <% } %>

          <!-- Примечание -->
          <div class="notice-block catalog-notice">
            <span class="notice-block__icon">ℹ</span>
            <p><%= content['site.notice'] || '' %></p>
          </div>

        </div><!-- /catalog-main -->
      </div><!-- /catalog-layout -->

    </div><!-- /container -->
  </main>

  <%- include('_footer') %>

  <script src="/js/site.js"></script>
  <script>
  (function() {
    // ── Аккордеоны ──
    document.querySelectorAll('.f-accordion__header').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var acc = this.closest('.f-accordion');
        var open = acc.classList.toggle('is-open');
        this.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    });

    // ── Мобильный drawer ──
    var mobBtn  = document.getElementById('mob-filter-btn');
    var sidebar = document.getElementById('filters-sidebar');
    var backdrop = document.getElementById('filters-backdrop');
    var closeBtn = document.getElementById('filters-close');
    var applyBtn = document.getElementById('filters-apply-btn');

    function openDrawer() {
      sidebar.classList.add('is-open');
      backdrop.classList.add('is-visible');
      document.body.style.overflow = 'hidden';
      if (mobBtn) mobBtn.setAttribute('aria-expanded', 'true');
    }
    function closeDrawer() {
      sidebar.classList.remove('is-open');
      backdrop.classList.remove('is-visible');
      document.body.style.overflow = '';
      if (mobBtn) mobBtn.setAttribute('aria-expanded', 'false');
    }

    if (mobBtn)   mobBtn.addEventListener('click', openDrawer);
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
    if (backdrop) backdrop.addEventListener('click', closeDrawer);
    if (applyBtn) applyBtn.addEventListener('click', closeDrawer);
  })();
  </script>
</body>
</html>
